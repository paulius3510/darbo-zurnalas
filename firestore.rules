rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{id} {
      allow read: if true;
      allow write: if request.auth != null && (resource == null || request.auth.uid == resource.data.uid);
    }
    match /workEntries/{id} {
      allow read: if true;
      allow write: if request.auth != null && (resource == null || request.auth.uid == resource.data.uid);
    }
    match /materials/{id} {
      allow read: if true;
      allow write: if request.auth != null && (resource == null || request.auth.uid == resource.data.uid);
    }
  }
}
